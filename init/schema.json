{
  "tables": [
    {
      "slug": "contacts",
      "name": "Contacts",
      "icon": "User",
      "fields": [
        { "slug": "name", "name": "Name", "field_type": "text", "required": true },
        { "slug": "email", "name": "Email", "field_type": "text", "required": false },
        { "slug": "phone", "name": "Phone", "field_type": "text", "required": false },
        { "slug": "company", "name": "Company", "field_type": "text", "required": false },
        { "slug": "created_at", "name": "Created At", "field_type": "datetime", "required": false }
      ]
    },
    {
      "slug": "pipeline_stages",
      "name": "Pipeline Stages",
      "icon": "Columns",
      "fields": [
        { "slug": "name", "name": "Name", "field_type": "text", "required": true },
        { "slug": "slug", "name": "Slug", "field_type": "text", "required": false },
        { "slug": "sort_order", "name": "Sort Order", "field_type": "number", "required": false }
      ]
    },
    {
      "slug": "deals",
      "name": "Deals",
      "icon": "Briefcase",
      "fields": [
        { "slug": "name", "name": "Name", "field_type": "text", "required": true },
        {
          "slug": "contact_id",
          "name": "Contact",
          "field_type": "relation",
          "required": false,
          "relation_table_slug": "contacts"
        },
        {
          "slug": "pipeline_stage_id",
          "name": "Pipeline Stage",
          "field_type": "relation",
          "required": false,
          "relation_table_slug": "pipeline_stages"
        },
        { "slug": "value", "name": "Value", "field_type": "currency", "required": false },
        {
          "slug": "status",
          "name": "Status",
          "field_type": "select",
          "required": false,
          "validation": { "options": ["open", "won", "lost"] }
        },
        { "slug": "created_at", "name": "Created At", "field_type": "datetime", "required": false }
      ]
    },
    {
      "slug": "activities",
      "name": "Activities",
      "icon": "Activity",
      "fields": [
        { "slug": "subject", "name": "Subject", "field_type": "text", "required": true },
        {
          "slug": "deal_id",
          "name": "Deal",
          "field_type": "relation",
          "required": false,
          "relation_table_slug": "deals"
        },
        {
          "slug": "type",
          "name": "Type",
          "field_type": "select",
          "required": false,
          "validation": { "options": ["call", "email", "meeting"] }
        },
        { "slug": "created_at", "name": "Created At", "field_type": "datetime", "required": false }
      ]
    }
  ],
  "reports": [
    {
      "name": "Deals by stage",
      "description": "Count of deals grouped by pipeline stage",
      "config": {
        "type": "table",
        "tableSlug": "deals",
        "groupBy": ["pipeline_stage_id"],
        "aggregates": [{ "field": "id", "fn": "count" }],
        "sort": "pipeline_stage_id",
        "order": "asc",
        "limit": 50
      }
    },
    {
      "name": "Revenue forecast",
      "description": "Sum of won deal values",
      "config": {
        "type": "sql",
        "sql": "SELECT COALESCE(SUM(value), 0)::numeric AS total_revenue FROM deals WHERE tenant_id = $tenant_id$ AND status = 'won'"
      }
    }
  ],
  "workflows": [
    {
      "name": "deal.won → email to owner",
      "definition": {
        "nodes": [
          {
            "id": "trigger-1",
            "type": "trigger",
            "data": {
              "trigger_type": "event",
              "trigger_event_type": "deal.won"
            },
            "position": { "x": 0, "y": 0 }
          },
          {
            "id": "email-1",
            "type": "email",
            "data": {
              "to_mode": "users",
              "users_role_filter": "owner,admin",
              "subject": "Deal won: {{record.name}}",
              "body": "Deal {{record.name}} ({{record.value}}) has been marked as won. Congrats!"
            },
            "position": { "x": 240, "y": 0 }
          }
        ],
        "edges": [{ "id": "e1", "source": "trigger-1", "target": "email-1" }]
      }
    },
    {
      "name": "contact.created → (placeholder assign)",
      "definition": {
        "nodes": [
          {
            "id": "trigger-1",
            "type": "trigger",
            "data": {
              "trigger_type": "event",
              "trigger_event_type": "contact.created"
            },
            "position": { "x": 0, "y": 0 }
          }
        ],
        "edges": []
      }
    }
  ]
}
